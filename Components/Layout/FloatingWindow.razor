@inject WindowService WinSvc
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="float-win @(Model.IsFloating ? "float-win-floating" : "float-win-docked")"
     style="@PositionStyle">

    <div class="retro-window h-full flex flex-col">

        <div class="retro-window-title float-win-titlebar"
             @onmousedown="HandleTitleMouseDown">
            <span class="text-[8px] tracking-widest">@Model.Title</span>
            <div class="retro-window-controls" @onmousedown:stopPropagation="true">
                <RetroWindowButton Variant="minimize" />
                <RetroWindowButton Variant="maximize" />
                <RetroWindowButton Variant="close" OnClick="HandleClose" />
            </div>
        </div>

        <div class="retro-window-body flex-1 overflow-y-auto">
            <p class="text-[9px] opacity-40">// @Model.Title</p>
        </div>

    </div>
</div>

@code {
    [Parameter] public WindowModel Model { get; set; } = default!;
    [Parameter] public EventCallback<(int id, double x, double y)> OnDragComplete { get; set; }

    private DotNetObjectReference<FloatingWindow>? _selfRef;
    private double _pendingStartX, _pendingStartY;
    private bool _pendingDrag = false;
    private string PositionStyle => Model.IsFloating
    ? $"position:absolute; left:{Model.X}px; top:{Model.Y}px; width:{Model.Width}px; height:{Model.Height}px; z-index:1000;"
    : $"position:absolute; top:{20 + (Model.Id - 1) * 30}px; left:20px; width:340px; height:160px; z-index:{10 + Model.Id};";
    protected override void OnInitialized()
    {
        _selfRef = DotNetObjectReference.Create(this);
    }

    private async Task HandleTitleMouseDown(MouseEventArgs e)
    {
        await JS.InvokeVoidAsync("console.log", $"[DRAG] click en ventana {Model.Id}");

        if (!Model.IsFloating)
        {
            // 1. Guardar coords para usarlas DESPUÉS del re-render
            _pendingStartX = e.ClientX;
            _pendingStartY = e.ClientY;
            _pendingDrag = true;

            // 2. Esto dispara re-render
            WinSvc.FloatWindow(Model.Id, e.ClientX - 10, e.ClientY - 10);
            return; // 👈 salir aquí, el drag se inicia en OnAfterRenderAsync
        }

        // Si ya es floating, iniciar drag directo
        await StartDrag(e.ClientX, e.ClientY);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 3. Aquí el componente ya re-renderizó y _selfRef es válido
        if (_pendingDrag)
        {
            _pendingDrag = false;
            await StartDrag(_pendingStartX, _pendingStartY);
        }
    }

    private async Task StartDrag(double clientX, double clientY)
    {
        try
        {
            await JS.InvokeVoidAsync("dragInterop.startDrag",
                _selfRef,           // ✅ ahora sí es el ref válido
                clientX, clientY,
                Model.X, Model.Y);
            await JS.InvokeVoidAsync("console.log", "[DRAG] JS OK");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.error", $"[DRAG ERROR] {ex.Message}");
        }
    }

    [JSInvokable]
    public void OnDragMove(double x, double y)
    {
        WinSvc.UpdatePosition(Model.Id, x, y);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnDragEnd(double x, double y)
    {
        WinSvc.UpdatePosition(Model.Id, x, y);
        await OnDragComplete.InvokeAsync((Model.Id, x, y));
        StateHasChanged();
    }

    private async Task HandleClose()
    {
        await JS.InvokeVoidAsync("console.log", $"close clicked {Model.Id}");
        WinSvc.CloseWindow(Model.Id);
    }

    // 👇 IAsyncDisposable para limpiar JS también
    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("dragInterop.cleanup");
        }
        catch { }

        _selfRef?.Dispose();
        _selfRef = null;
    }
}