@inherits LayoutComponentBase
@inject WindowService WinSvc
@implements IDisposable

<div class="cantask-shell crt">

    <NavBar />

    <main class="cantask-grid" style="position:relative;">

        @* LEFT — ventanas dockeadas *@
        <section style="grid-column: span 6;" class="min-h-0 flex flex-col gap-[5px]">
            @{
                var leftWins = WinSvc.Windows.Where(w => w.Zone == DockZone.Left).ToList();
            }
            @if (leftWins.Count == 0)
            {
                <RetroWindow Title="// PORTAL" Class="h-full" BodyClass="overflow-y-auto h-full">
                    @Body
                </RetroWindow>
            }
            else
            {
                @foreach (var win in leftWins)
                {
                    <RetroWindow Title="@win.Title" Class="flex-1" BodyClass="overflow-y-auto">
                        <p class="text-[9px] opacity-40">// @win.Title</p>
                    </RetroWindow>
                }
            }
        </section>

        @* CENTER *@
        <section style="grid-column: span 4;" class="min-h-0">
            @{
                var centerWin = WinSvc.Windows.FirstOrDefault(w => w.Zone == DockZone.Center);
            }
            @if (centerWin is not null)
            {
                <RetroWindow Title="@centerWin.Title" Class="h-full" BodyClass="overflow-y-auto h-full">
                    <p class="text-[9px] opacity-40">// @centerWin.Title</p>
                </RetroWindow>
            }
            else
            {
                <RetroWindow Title="" ShowControls="false" Class="h-full" BodyClass="overflow-hidden p-0 h-full">
                    <div class="retro-breaking-cascade">
                        <div class="retro-cascade-pair" style="opacity:0.10;">
                            <div class="retro-cascade-small">BREAKING</div>
                            <RetroCascade Filled="false" />
                        </div>
                        <div class="retro-cascade-pair" style="opacity:0.22;">
                            <div class="retro-cascade-small">BREAKING</div>
                            <RetroCascade Filled="false" />
                        </div>
                        <div class="retro-cascade-pair" style="opacity:1;">
                            <div class="retro-cascade-small">BREAKING</div>
                            <RetroCascade Filled="true" />
                        </div>
                        <div class="retro-cascade-pair" style="opacity:0.22;">
                            <div class="retro-cascade-small">BREAKING</div>
                            <RetroCascade Filled="false" />
                        </div>
                        <div class="retro-cascade-pair" style="opacity:0.10;">
                            <div class="retro-cascade-small">BREAKING</div>
                            <RetroCascade Filled="false" />
                        </div>
                    </div>
                </RetroWindow>
            }
        </section>

        @* RIGHT *@
        <section style="grid-column: span 2;" class="min-h-0 flex flex-col gap-[5px]">
            @{
                var rightTop = WinSvc.Windows.FirstOrDefault(w => w.Zone == DockZone.RightTop);
                var rightBot = WinSvc.Windows.FirstOrDefault(w => w.Zone == DockZone.RightBottom);
            }

            @* TOP *@
            <div class="flex-1 min-h-0">
                @if (rightTop is not null)
                {
                    <RetroWindow Title="@rightTop.Title" Class="h-full" BodyClass="overflow-y-auto h-full">
                        <p class="text-[9px] opacity-40">// @rightTop.Title</p>
                    </RetroWindow>
                }
                else
                {
                    <div class="retro-window h-full flex items-center justify-center">
                        <div class="retro-circle"></div>
                    </div>
                }
            </div>

            @* BOTTOM *@
            <div class="flex-1 min-h-0">
                @if (rightBot is not null)
                {
                    <RetroWindow Title="@rightBot.Title" Class="h-full" BodyClass="overflow-y-auto h-full">
                        <p class="text-[9px] opacity-40">// @rightBot.Title</p>
                    </RetroWindow>
                }
                else
                {
                    <div class="retro-window h-full">
                        <div class="retro-kanji-block h-full">
                            <span>ポ</span>
                            <span>ー</span>
                            <span>タ</span>
                            <span>ル</span>
                        </div>
                    </div>
                }
            </div>

        </section>

        @* WindowManager — maneja flotantes y overlay de drag *@
        <WindowManager @ref="_winManager" />

    </main>

    <footer class="retro-bottombar">
        <div class="retro-checker"></div>
        <NavLink href="" Match="NavLinkMatch.All" class="retro-bottom-item" ActiveClass="retro-bottom-active">ポータル</NavLink>
        <div class="retro-bottom-item retro-bottom-icon">
            <svg width="12" height="14" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="6" cy="3.5" r="2.5" stroke="currentColor" stroke-width="1" />
                <path d="M1 13c0-2.761 2.239-5 5-5s5 2.239 5 5" stroke="currentColor" stroke-width="1" />
            </svg>
        </div>
        <NavLink href="counter" class="retro-bottom-item" ActiveClass="retro-bottom-active">001 // COUNTER</NavLink>
        <NavLink href="weather" class="retro-bottom-item" ActiveClass="retro-bottom-active">002 // WEATHER</NavLink>
    </footer>

</div>

@code {
    private WindowManager? _winManager;

    protected override void OnInitialized()
        => WinSvc.OnChange += StateHasChanged;

    public void Dispose()
        => WinSvc.OnChange -= StateHasChanged;
}