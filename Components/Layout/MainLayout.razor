@inherits LayoutComponentBase

<div class="cantask-shell crt">

    <NavBar />

    <main class="cantask-grid">

        @* LEFT — página actual *@
        <section style="grid-column: span 6;" class="min-h-0">
            <RetroWindow Title="// PORTAL" Class="h-full" BodyClass="overflow-y-auto h-full">
                @Body
            </RetroWindow>
        </section>

        @* CENTER — Breaking News *@
        <section style="grid-column: span 4;" class="min-h-0">
            <RetroWindow Title="" ShowControls="false" Class="h-full" BodyClass="overflow-hidden p-0 h-full">
                <div class="retro-breaking-cascade">
                    @for (int i = 0; i < 6; i++)
                    {
                        var opacity = Math.Max(0.06, 1.0 - (i * 0.18));
                        var scale = Math.Max(0.5, 1.0 - (i * 0.1));
                        <div class="retro-cascade-pair" style="opacity:@opacity.ToString("F2");">
                            <div class="retro-cascade-small">BREAKING</div>
                            <div class="retro-cascade-big" style="transform: scaleX(@scale.ToString("F2")); transform-origin: left;">NEWS</div>
                        </div>
                    }
                </div>
            </RetroWindow>
        </section>

        @* RIGHT — sidebar dividido *@
        <section style="grid-column: span 2;" class="min-h-0">
            <RetroSidebar />
        </section>

    </main>

    @* BOTTOM STATUS BAR — igual que la foto *@
    <footer class="retro-bottombar">
        <div class="retro-checker"></div>
        <NavLink href="" Match="NavLinkMatch.All" class="retro-bottom-item" ActiveClass="retro-bottom-active">ポータル</NavLink>
        <div class="retro-bottom-item retro-bottom-icon">
            <svg width="12" height="14" viewBox="0 0 12 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="6" cy="3.5" r="2.5" stroke="currentColor" stroke-width="1" />
                <path d="M1 13c0-2.761 2.239-5 5-5s5 2.239 5 5" stroke="currentColor" stroke-width="1" />
            </svg>
        </div>
        <NavLink href="counter" class="retro-bottom-item" ActiveClass="retro-bottom-active">001 // COUNTER</NavLink>
        <NavLink href="weather" class="retro-bottom-item" ActiveClass="retro-bottom-active">002 // WEATHER</NavLink>
    </footer>

</div>