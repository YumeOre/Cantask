<div class="retro-window @Class">
    @if (!string.IsNullOrEmpty(Title) || ShowControls)
    {
        <div class="retro-window-title">
            <span>@Title</span>
            @if (ShowControls)
            {
                <div class="retro-window-controls">
                    <RetroWindowButton Variant="minimize" />
                    <RetroWindowButton Variant="maximize" />
                    <RetroWindowButton Variant="close" />
                </div>
            }
        </div>
    }
    <div class="retro-window-body @BodyClass">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public bool ShowControls { get; set; } = true;
    [Parameter] public string Class { get; set; } = "";
    [Parameter] public string BodyClass { get; set; } = "";
}