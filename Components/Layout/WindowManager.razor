@inject WindowService WinSvc
@implements IDisposable

@* ✅ Flotantes *@
@foreach (var win in WinSvc.Windows.Where(w => w.IsFloating))
{
    <FloatingWindow @key="win.Id" Model="win" OnDragComplete="HandleDragComplete" />
}

@* ✅ Docked Left también aquí *@
@foreach (var win in WinSvc.Windows.Where(w => !w.IsFloating && w.Zone == DockZone.Left))
{
    <FloatingWindow @key="win.Id" Model="win" OnDragComplete="HandleDragComplete" />
}

@code {
    protected override void OnInitialized()
        => WinSvc.OnChange += StateHasChanged;

    public void Dispose()
        => WinSvc.OnChange -= StateHasChanged;

    private Task HandleDragComplete((int id, double x, double y) args)
    {
        var (id, x, y) = args;

        if (x > 580 && x < 950)
            WinSvc.DockWindow(id, DockZone.Center);
        else if (x >= 950 && y < 300)
            WinSvc.DockWindow(id, DockZone.RightTop);
        else if (x >= 950 && y >= 300)
            WinSvc.DockWindow(id, DockZone.RightBottom);

        StateHasChanged();
        return Task.CompletedTask;
    }
}