@page "/"

<div class="home-wrap">

    @* HEADER *@
    <div class="home-header">
        <span class="home-header-title">// SYSTEM STATUS</span>
        <span class="home-header-date">ONLINE • @DateTime.Now.ToString("dd-MM-yyyy")</span>
    </div>

    @* PANELS *@
    <div class="home-panels">

        @* LEFT — Cognitive Metrics *@
        <div class="home-panel">
            <div class="home-panel-label">COGNITIVE METRICS</div>
            <div class="home-chart-box">
                <svg viewBox="0 0 300 120" class="home-chart-svg">
                    <path d="M10,100 C60,20 100,110 160,50 C200,10 240,60 290,30"
                          fill="none" stroke="var(--c-accent)" stroke-width="1.5" opacity="0.9" />
                    <circle cx="290" cy="30" r="3" fill="var(--c-accent)" />
                </svg>
                <div class="corner tl"></div>
                <div class="corner tr"></div>
                <div class="corner bl"></div>
                <div class="corner br"></div>
            </div>
        </div>

        @* RIGHT — Biometric Scan *@
        <div class="home-panel">
            <div class="home-panel-label">BIOMETRIC SCAN</div>
            <div class="home-chart-box">
                <div class="home-radar">
                    <div class="home-radar-outer">
                        <div class="home-radar-inner">
                            <div class="home-radar-dot"></div>
                        </div>
                        <div class="home-radar-h"></div>
                        <div class="home-radar-v"></div>
                    </div>
                </div>
                <div class="corner tl"></div>
                <div class="corner tr"></div>
                <div class="corner bl"></div>
                <div class="corner br"></div>
            </div>
        </div>

    </div>

    @* INFO TABLE *@
    <div class="home-info">
        <div class="home-info-row">
            <span class="home-info-key">NAME............</span>
            <span class="home-info-val">CANTASK SYSTEM</span>
        </div>
        <div class="home-info-row">
            <span class="home-info-key">VERSION.........</span>
            <span class="home-info-val">.NET 10 / MAUI BLAZOR</span>
        </div>
        <div class="home-info-row">
            <span class="home-info-key">STATUS..........</span>
            <span class="home-info-val home-info-ok">RUNNING</span>
        </div>
        <div class="home-info-row">
            <span class="home-info-key">BUILD...........</span>
            <span class="home-info-val">@DateTime.Now.ToString("yyyy.MM.dd")</span>
        </div>
    </div>

    @* FOOTER *@
    <div class="home-footer">
        <RetroButton>ACCESS PANEL</RetroButton>
        <div class="home-dots">
            <span class="home-dot-o"></span>
            <span class="home-dot-o"></span>
            <span class="home-dot-o home-dot-filled"></span>
        </div>
    </div>

</div>