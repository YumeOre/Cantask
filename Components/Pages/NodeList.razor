@page "/nodes"
@using Cantask.Models
@using Cantask.Services
@inject NodeService NodeService
@inject DevService DevService
@inject ProjectService ProjectService

<h3>Seleccionar Proyecto</h3>

<select @onchange="OnProjectChanged">
    <option value="">Selecciona un proyecto</option>

    @foreach (var project in Projects)
    {
        <option value="@project.Id">@project.Name</option>
    }
</select>

<hr />

<h3>Lista de Nodos</h3>

@if (!string.IsNullOrEmpty(error))
{
    <p style="color:red;">@error</p>
}

@if (SelectedProjectIdView == Guid.Empty)
{
    <p>Selecciona un proyecto para ver nodos.</p>
}
else if (Nodes.Count == 0)
{
    <p>No hay nodos en este proyecto.</p>
}
else
{
    <ul>
        @foreach (var node in Nodes)
        {
            <li>
                <strong>@node.Type</strong>: @node.Content
            </li>
        }
    </ul>
}

<hr />

<h3>Crear Nodo</h3>

@if (SelectedProjectIdView == Guid.Empty)
{
    <p>Debes seleccionar un proyecto primero.</p>
}
else
{
    <div>
        <label>Tipo:</label>
        <select @bind="SelectedType">
            @foreach (NodeType type in Enum.GetValues(typeof(NodeType)))
            {
                <option value="@type">@type</option>
            }
        </select>
    </div>

    <div style="margin-top:10px;">
        <label>Contenido:</label>
        <input @bind="NewContent" placeholder="Escribe algo..." />
    </div>

    <div style="margin-top:10px;">
        <button type="button" @onclick="CrearNodo">Agregar Nodo</button>
    </div>
}

<p>@mensaje</p>

<button style="background:red; color:white;" @onclick="ResetAll">
    ⚠ Resetear TODO
</button>

@code {
    private List<Node> Nodes = new();
    private List<Project> Projects = new();

    private NodeType SelectedType = NodeType.Concept;
    private string NewContent = "";
    private string mensaje = "";
    private string error = "";

    private Guid SelectedProjectIdView = Guid.Empty;

    protected override void OnInitialized()
    {
        try
        {
            Projects = ProjectService.GetAllProjects();
        }
        catch (Exception ex)
        {
            error = $"Error al cargar datos: {ex.Message}";
        }
    }

    private void OnProjectChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            SelectedProjectIdView = id;
            CargarNodos();
        }
        else
        {
            SelectedProjectIdView = Guid.Empty;
            Nodes.Clear();
        }
    }

    private void CargarNodos()
    {
        Nodes = NodeService.GetNodesByProject(SelectedProjectIdView);
    }

    private void CrearNodo()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(NewContent))
            {
                mensaje = "El contenido no puede estar vacío.";
                return;
            }

            var node = NodeService.CreateNode(
                SelectedType,
                NewContent,
                SelectedProjectIdView
            );

            mensaje = $"Nodo creado: {node.Id}";

            CargarNodos();
            NewContent = "";
        }
        catch (Exception ex)
        {
            error = ex.InnerException != null
                ? ex.InnerException.Message
                : ex.Message;
        }
    }

    private void ResetAll()
    {
        DevService.ClearAllData();

        Nodes.Clear();
        Projects = ProjectService.GetAllProjects();
        SelectedProjectIdView = Guid.Empty;

        mensaje = "Sistema reiniciado";
    }
}